flowchart TD
    subgraph "Entry"
        Main["__main__ / app.main()"]:::infra
        Single(["single-instance guard — mutex/flock + activate ping (localhost:52697)"]):::infra
    end

    subgraph "Core"
        App("App — state machine idle/recording/processing"):::backend
        Events(["event queue (App.post)"]):::queue
        Poll("QTimer poll (main thread, 100ms)"):::backend
        Config[("config.json (DEFAULTS)")]:::database
        Net["netutil — insecure-SSL switch (corporate proxy)"]:::infra
    end

    subgraph "Input and UI (Qt main thread)"
        Hotkeys("Hotkeys — global hotkey, pynput"):::frontend
        Tray("Tray — QSystemTrayIcon"):::frontend
        Overlay("Overlay + VoiceMicWidget"):::frontend
        Settings("SettingsWindow"):::frontend
        Onboarding("OnboardingWizard — first-run setup"):::frontend
        Theme["theme / icons / qtutil / keymap / widgets / choices"]:::frontend
    end

    subgraph "Processing (worker threads)"
        Recorder("Recorder — sounddevice"):::backend
        Transcriber("Transcriber — faster-whisper"):::backend
        TranscriberOV("OpenVinoTranscriber — OpenVINO GenAI (Intel GPU/NPU)"):::backend
        Assistant("Assistant — LLM post-process"):::backend
        Injector("Injector — paste/type at cursor"):::backend
        LiveType("LiveTyper — live typing while recording"):::backend
        Mute("MuteIntegrations — mute other apps"):::backend
        Diag("DiagnosticsEngine — settings self-tests"):::backend
    end

    subgraph "Persistence"
        History[("history.json — text only")]:::database
        Autostart["autostart — start with OS"]:::infra
        Updater("Updater — GitHub Releases"):::backend
    end

    subgraph "External"
        HF{{"Hugging Face — model download"}}:::external
        LLM{{"OpenAI-compatible API (Ollama, ...)"}}:::external
        GH{{"GitHub Releases API"}}:::external
        OS{{"Focused window / other apps"}}:::external
    end

    Main -->|"acquire"| Single
    Single -->|"post activate (second launch)"| Events
    Main -->|"run"| App
    App --> Config
    App -->|"apply insecure_ssl (verify= + HF backend)"| Net
    App --> Poll
    Poll -->|"drain"| Events

    Hotkeys -->|"post press/release"| Events
    Tray -->|"post toggle/settings/quit"| Events
    Overlay -->|"post toggle/cancel"| Events
    Settings -->|"apply_settings"| App
    App --> Tray
    App --> Overlay
    App --> Settings
    App -->|"first run (no config yet)"| Onboarding
    Onboarding -->|"essential settings"| Config
    Overlay --- Theme
    Settings --- Theme

    App -->|"start/stop"| Recorder
    App -->|"_process worker"| Transcriber
    App -->|"backend = openvino (factory)"| TranscriberOV
    Recorder -->|"audio frames"| Transcriber
    Recorder -->|"audio frames"| TranscriberOV
    Transcriber -->|"text"| Assistant
    Assistant -->|"cleaned text"| Injector
    Transcriber -->|"text (assistant off)"| Injector
    App -->|"on record start/stop"| Mute
    App -->|"live typing worker (per take)"| LiveType
    Recorder -->|"uncommitted audio"| LiveType
    LiveType -->|"preview_segments"| Transcriber
    LiveType -->|"type stable text"| Injector

    Settings -->|"model download / mic + transcription test"| Diag
    Diag -->|"test clip"| Recorder
    Diag -->|"snapshot transcriber"| Transcriber
    Diag -->|"snapshot transcriber"| TranscriberOV

    Injector -->|"insert at cursor"| OS
    Mute -->|"synthesize mute keybind"| OS
    Transcriber -->|"first-use download"| HF
    TranscriberOV -->|"first-use download (OpenVINO IR)"| HF
    Assistant -->|"chat/completions"| LLM
    Updater -->|"check/download"| GH
    App --> Updater
    App -->|"record text"| History
    App --> Autostart

